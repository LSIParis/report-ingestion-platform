# Copier en .env.prod sur le VPS puis renseigner. NE JAMAIS committer .env.prod.
# Lancement : docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# --- Domaines (DNS A/AAAA vers l'IP du VPS requis pour les deux) ---
DOMAIN=rapports.mondomaine.tld
FILES_DOMAIN=files.rapports.mondomaine.tld
ACME_EMAIL=admin@mondomaine.tld

# --- Secrets DB / MinIO (générer des valeurs fortes : openssl rand -base64 24) ---
POSTGRES_PASSWORD=CHANGE_ME_strong
MINIO_ROOT_USER=reportminio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong

# --- Boîte mail machine (ingestion IMAP) ---
IMAP_HOST=imap.mondomaine.tld
IMAP_USER=reports@lsiparis.tech
IMAP_PASSWORD=CHANGE_ME

# --- Observabilité (optionnel) ---
SENTRY_DSN=

# NB : les clés JWT ne sont PAS ici — elles sont montées comme fichiers
# depuis ../keys/ (jwt_priv.pem / jwt_pub.pem). Voir DEPLOY.md.
