# Copier en .env puis renseigner. `docker compose` charge ce fichier automatiquement.

# Clés JWT (générées via openssl — voir README). Injectées dans le service api.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Boîte mail partagée (ingestion IMAP en dev)
IMAP_HOST=imap.exemple.com
IMAP_USER=reports@lsiparis.tech
IMAP_PASSWORD=change-me
